# =============================================================================
# PROPINANDO - Environment Variables Template
# Copiar este archivo como .env y completar con valores reales
# =============================================================================

# =============================================================================
# AUTHENTICATION (JWT)
# =============================================================================
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_32_chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/propinando_db?schema=public

# =============================================================================
# REDIS (Session Cache)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# ENCRYPTION (AES-256-GCM)
# =============================================================================
ENCRYPTION_KEY=your_32_char_encryption_key_here
ENCRYPTION_IV_LENGTH=16

# =============================================================================
# MERCADO PAGO
# =============================================================================
# Sandbox (Pruebas)
MERCADO_PAGO_SANDBOX=true
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADO_PAGO_CLIENT_ID=TEST_xxxxxxxxxxxxx
MERCADO_PAGO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook Security
MERCADO_PAGO_WEBHOOK_SECRET=your_webhook_secret_key_here

# Callback URLs
MERCADO_PAGO_CALLBACK_URL=https://yourdomain.com/api/webhooks/mercado-pago
MERCADO_PAGO_SUCCESS_URL=https://yourdomain.com/payment/success
MERCADO_PAGO_PENDING_URL=https://yourdomain.com/payment/pending
MERCADO_PAGO_FAILURE_URL=https://yourdomain.com/payment/failure

# =============================================================================
# N8N (Automations)
# =============================================================================
N8N_WEBHOOK_URL=http://localhost:5678/webhook/propinando
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# =============================================================================
# SENTRY (Error Tracking - Opcional)
# =============================================================================
SENTRY_DSN=

// =============================================================================
// PropinanDO - Prisma Schema
// Database: PostgreSQL
// Version: 1.0.0
// 
// Modelo Financiero: P = N + C (8% comisión)
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  SYSTEM_OWNER
  STORE_ADMIN
  EMPLOYEE
  CUSTOMER
}

enum SplitMode {
  equal
  percentage
  manual
}

enum TipStatus {
  INITIATED
  PAID
  CANCELLED
  FAILED
}

// =============================================================================
// USERS
// =============================================================================

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique @db.VarChar(255)
  passwordHash      String    @map("password_hash")
  firstName         String    @map("first_name") @db.VarChar(100)
  lastName          String    @map("last_name") @db.VarChar(100)
  phone             String?   @db.VarChar(20)
  dniEncrypted      String?   @map("dni_encrypted")
  photoUrl          String?   @map("photo_url") @db.VarChar(500)
  role              UserRole  @default(EMPLOYEE)
  isActive          Boolean   @default(true) @map("is_active")
  identityVerified  Boolean   @default(false) @map("identity_verified")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  venueAdmins      VenueAdmin[]
  employee         Employee?
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  propinandoConfig PropinandoConfig?
  tipsCreated      Tip[]      @relation("TipCreator")
  tipsPaid         Tip[]      @relation("TipPayer")

  @@index([email], unique: true)
  @@map("users")
}

// =============================================================================
// VENUES (Multi-local System)
// =============================================================================

model Venue {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(255)
  slug             String    @unique @db.VarChar(100)
  cuit             String?   @db.VarChar(20)
  address          String?   @db.VarChar(500)
  type             String?   @db.VarChar(50)
  logoUrl          String?   @map("logo_url") @db.VarChar(500)
  qrCode           String?   @map("qr_code") @db.Text
  commissionRate   Decimal   @default(0.08) @map("commission_rate") @db.Decimal(5, 4)
  mpAccessToken    String?   @map("mp_access_token") @db.Text
  isActive         Boolean   @default(true) @map("is_active")
  isSandbox        Boolean   @default(true) @map("is_sandbox")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  venueAdmins      VenueAdmin[]
  sectors          Sector[]
  employees        Employee[]

  @@index([slug], unique: true)
  @@map("venues")
}

// =============================================================================
// VENUE ADMINS (N:M Relationship)
// =============================================================================

model VenueAdmin {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  venueId   String   @map("venue_id") @db.Uuid
  isOwner   Boolean  @default(false) @map("is_owner")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([venueId])
  @@map("venue_admins")
}

// =============================================================================
// SECTORS
// =============================================================================

model Sector {
  id           String     @id @default(uuid()) @db.Uuid
  venueId      String     @map("venue_id") @db.Uuid
  name         String     @db.VarChar(100)
  splitMode    SplitMode  @default(equal) @map("split_mode")
  isActive     Boolean    @default(true) @map("is_active")
  displayOrder Int        @default(0) @map("display_order")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  employees Employee[]
  tips      Tip[]

  @@index([venueId])
  @@map("sectors")
}

// =============================================================================
// EMPLOYEES
// =============================================================================

model Employee {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  venueId          String    @map("venue_id") @db.Uuid
  sectorId         String    @map("sector_id") @db.Uuid
  displayName      String    @map("display_name") @db.VarChar(100)
  photoUrl         String?   @map("photo_url") @db.VarChar(500)
  splitPercentage  Decimal   @default(100) @map("split_percentage") @db.Decimal(5, 2)
  paymentAccount   String?   @map("payment_account") @db.Text
  qrPersonalToken  String    @default(uuid()) @unique @map("qr_personal_token")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue    Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sector   Sector    @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  tips     Tip[]
  tipSplits TipSplit[]

  @@index([userId], unique: true)
  @@index([venueId])
  @@index([qrPersonalToken], unique: true)
  @@map("employees")
}

// =============================================================================
// TIPS (Propinas)
// =============================================================================

model Tip {
  id                String    @id @default(uuid()) @db.Uuid
  externalReference String    @unique @map("external_reference")
  venueId           String    @map("venue_id") @db.Uuid
  sectorId          String    @map("sector_id") @db.Uuid
  employeeId        String    @map("employee_id") @db.Uuid
  grossAmount       Decimal   @map("gross_amount") @db.Decimal(12, 2)
  commissionRate    Decimal   @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount  Decimal   @map("commission_amount") @db.Decimal(12, 2)
  netAmount         Decimal   @map("net_amount") @db.Decimal(12, 2)
  rating            Int?      @db.Int
  comment           String?   @db.VarChar(500)
  status            TipStatus @default(INITIATED)
  mpPreferenceId    String?   @map("mp_preference_id") @db.VarChar(50)
  mpPaymentId       String?   @map("mp_payment_id") @db.VarChar(50)
  mpStatus          String?   @map("mp_status") @db.VarChar(50)
  customerEmail     String?   @map("customer_email") @db.VarChar(255)
  paidAt            DateTime? @map("paid_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sector    Sector     @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tipSplits TipSplit[]

  // Validations (handled at application level)
  // CHECK: gross_amount > 0
  // CHECK: rating >= 1 AND rating <= 5
  // CHECK: gross_amount = commission_amount + net_amount

  @@index([venueId])
  @@index([employeeId])
  @@index([status])
  @@index([mpPaymentId])
  @@index([createdAt])
  @@index([externalReference], unique: true)
  @@map("tips")
}

// =============================================================================
// TIP SPLITS (Distribución entre Empleados)
// =============================================================================

model TipSplit {
  id          String    @id @default(uuid()) @db.Uuid
  tipId       String    @map("tip_id") @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  netAmount   Decimal   @map("net_amount") @db.Decimal(12, 2)
  percentage  Decimal   @db.Decimal(5, 2)
  paidAt      DateTime? @map("paid_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  tip      Tip      @relation(fields: [tipId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tipId])
  @@index([employeeId])
  @@map("tip_splits")
}

// =============================================================================
// PROPINANDO CONFIG (Configuración Global)
// =============================================================================

model PropinandoConfig {
  id             String   @id @default(uuid()) @db.Uuid
  commissionRate Decimal  @default(0.08) @map("commission_rate") @db.Decimal(5, 4)
  updatedById    String   @map("updated_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  updatedBy User @relation(fields: [updatedById], references: [id], onDelete: Restrict)

  @@map("propinando_config")
}

// =============================================================================
// REFRESH TOKENS
// =============================================================================

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================================================
// AUDIT LOGS
// =============================================================================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(50)
  entityId  String?  @map("entity_id") @db.Uuid
  payload   Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

# ============================================================
# Propinando - Variables de Entorno
# Copiar este archivo a .env y completar los valores
# ============================================================

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/propinando?schema=public"

# ============================================================
# JWT AUTHENTICATION
# ============================================================
JWT_SECRET="genera-un-secret-largo-y-aleatorio-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="genera-otro-secret-largo-y-aleatorio-min-32-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# MERCADO PAGO
# ============================================================
MP_ACCESS_TOKEN="APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
MP_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxx"
MP_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MP_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# SECURITY
# ============================================================
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
RATE_LIMIT_MAX_REQUESTS="100"
AUTH_RATE_LIMIT_MAX_REQUESTS="5"

# ============================================================
# FILE UPLOAD (Multer - Cloudinary u otro)
# ============================================================
UPLOAD_PROVIDER="cloudinary"
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="xxxxxxxxxxxxxx"
CLOUDINARY_API_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# N8N (Automatización)
# ============================================================
N8N_WEBHOOK_URL="https://tu-n8n-instance.com/webhook/tips"
N8N_API_KEY="n8n_api_key_opcional"

# ============================================================
# ENGRAM (Memoria - Opcional)
# ============================================================
ENGRAM_DATA_DIR="../memory"
